# ── Local development ────────────────────────────────────────────────────────
# Points the browser directly at the local NestJS dev server.
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ── Production (Vercel) ──────────────────────────────────────────────────────
# Set NEXT_PUBLIC_API_URL=/api and API_ORIGIN to the NestJS Vercel deployment URL.
# Next.js rewrites then proxy /api/* to API_ORIGIN server-side, so the browser
# makes same-origin requests and no CORS config is needed on the NestJS side.
#
# NEXT_PUBLIC_API_URL=/api
# API_ORIGIN=https://aivora-api.vercel.app
