# ── Local development ────────────────────────────────────────────────────────
# Points the browser directly at the local NestJS dev server.
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ── Production (Vercel) ──────────────────────────────────────────────────────
# Set NEXT_PUBLIC_API_URL=/api and API_ORIGIN to the NestJS Vercel deployment URL.
# NEXT_PUBLIC_API_URL is for browser-side calls: Next.js rewrites proxy /api/* to
# API_ORIGIN server-side, so the browser makes same-origin requests (no CORS config
# needed on the NestJS side) and the httpOnly auth cookie rides along automatically.
# API_ORIGIN is also required for server-side calls (Server Actions, Server Components,
# Route Handlers) — those have no page origin, so they build an absolute URL from it
# directly instead of going through the rewrite.
#
# NEXT_PUBLIC_API_URL=/api
# API_ORIGIN=https://aivora-api.vercel.app
