{
  "buildCommand": "(cd ../../packages/shared && npm run build) && npx prisma generate && npm run build",
  "installCommand": "cd ../.. && npm install",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ]
}
