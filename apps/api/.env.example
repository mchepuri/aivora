# PostgreSQL connection string
# Local dev:   postgresql://postgres:password@localhost:5432/aivora_db
# Neon (prod): postgresql://user:pass@host/db?sslmode=require&pgbouncer=true
DATABASE_URL="postgresql://postgres:password@localhost:5432/aivora_db"

# Port the API listens on locally (ignored in Vercel serverless)
API_PORT=3001

NODE_ENV=development

# Allowed CORS origin — must match the web app URL exactly (used for credentials)
# Local dev: http://localhost:3000  |  Prod: https://aivora.vercel.app
WEB_ORIGIN=http://localhost:3000

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-32-char-secret

# OpenRouter API key for AI features (Inventory Bot — free tier Llama)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
